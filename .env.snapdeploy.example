# SnapDeploy pre-alpha UI testing example.
# Configure real secrets (APP_KEY, database credentials, service tokens) in the SnapDeploy UI.

APP_NAME=NextGN
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.snapdeploy.app
TRACKER_ANNOUNCE_URL=https://example.snapdeploy.app/announce/%s

NEXTGN_PREALPHA_DEMO=true

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
FAKER_LOCALE=en_US
