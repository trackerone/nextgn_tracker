APP_NAME=Laravel
APP_ENV=production
APP_KEY=
# Never enable APP_DEBUG in production deployments
APP_DEBUG=false
# Production deployments must use public HTTPS URLs.
# For local development only, use http://127.0.0.1:8000 and a localhost announce URL in your local .env.
APP_URL=https://example.com
TRACKER_ANNOUNCE_URL=https://example.com/announce/%s

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Use database or another durable queue driver when running queue workers.
QUEUE_CONNECTION=sync

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
FAKER_LOCALE=en_US

# Database (tilpas hvis du faktisk bruger DB)
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite
